# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets to version control.

# ── RPC endpoints ──────────────────────────────────────────────────────────────
# Used in foundry.toml [rpc_endpoints]. Uncomment the networks you need.
# MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
LOCAL_URL=http://127.0.0.1:8545
RPC_URL=LOCAL_URL

# ── Deployment ─────────────────────────────────────────────────────────────────
# Your deployer wallet address (with 0x prefix)
# Create an account just for local tests:
# Use `cast wallet import ForgeDefault --interactive` to setup and use this key: 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# Leave it without password, so it's easier to use
DEPLOYER_ADDRESS=0xf39fd6e51aad88f6f4ce6ab8827279cfffb92266
# Setup the account for the real network:
# Use `cast wallet import ProductionDeployer --interactive`, grab the address and replace here


# ── Verification ───────────────────────────────────────────────────────────────
# ETHERSCAN_API_KEY=
# ARBISCAN_API_KEY=
# BASESCAN_API_KEY=
